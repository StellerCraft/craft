{
    "extends": "../../packages/config/tsconfig.json",
    "compilerOptions": {
        "types": ["vitest/globals", "node"],
        "paths": {
            "@/*": ["./src/*"],
            "@craft/types": ["../../packages/types/src"],
            "@craft/stellar": ["../../packages/stellar/src"]
